<![CDATA[Ctrl0 := Ctrl0 + 1; Ctrl1 := Ctrl1 * 2; IF Ctrl2 > 0 THEN Ctrl2 := Ctrl2 - 1; END_IF Ctrl3 := Ctrl3 OR Ctrl4; Ctrl4 := Ctrl4 + 1; Ctrl5 := Ctrl5 * 2; IF Ctrl6 > 0 THEN Ctrl6 := Ctrl6 - 1; END_IF Ctrl7 := Ctrl7 OR Ctrl8; Ctrl8 := Ctrl8 + 1; Ctrl9 := Ctrl9 * 2; IF Ctrl10 > 0 THEN Ctrl10 := Ctrl10 - 1; END_IF Ctrl11 := Ctrl11 OR Ctrl12; Ctrl12 := Ctrl12 + 1; Ctrl13 := Ctrl13 * 2; IF Ctrl14 > 0 THEN Ctrl14 := Ctrl14 - 1; END_IF Ctrl15 := Ctrl15 OR Ctrl16; Ctrl16 := Ctrl16 + 1; Ctrl17 := Ctrl17 * 2; IF Ctrl18 > 0 THEN Ctrl18 := Ctrl18 - 1; END_IF Ctrl19 := Ctrl19 OR Ctrl20; Ctrl20 := Ctrl20 + 1; Ctrl21 := Ctrl21 * 2; IF Ctrl22 > 0 THEN Ctrl22 := Ctrl22 - 1; END_IF Ctrl23 := Ctrl23 OR Ctrl24; Ctrl24 := Ctrl24 + 1; Ctrl25 := Ctrl25 * 2; IF Ctrl26 > 0 THEN Ctrl26 := Ctrl26 - 1; END_IF Ctrl27 := Ctrl27 OR Ctrl28; Ctrl28 := Ctrl28 + 1; Ctrl29 := Ctrl29 * 2; IF Ctrl30 > 0 THEN Ctrl30 := Ctrl30 - 1; END_IF Ctrl31 := Ctrl31 OR Ctrl32; Ctrl32 := Ctrl32 + 1; Ctrl33 := Ctrl33 * 2; IF Ctrl34 > 0 THEN Ctrl34 := Ctrl34 - 1; END_IF Ctrl35 := Ctrl35 OR Ctrl36; Ctrl36 := Ctrl36 + 1; Ctrl37 := Ctrl37 * 2; IF Ctrl38 > 0 THEN Ctrl38 := Ctrl38 - 1; END_IF Ctrl39 := Ctrl39 OR Ctrl40; Ctrl40 := Ctrl40 + 1; Ctrl41 := Ctrl41 * 2; IF Ctrl42 > 0 THEN Ctrl42 := Ctrl42 - 1; END_IF Ctrl43 := Ctrl43 OR Ctrl44; Ctrl44 := Ctrl44 + 1; Ctrl45 := Ctrl45 * 2; IF Ctrl46 > 0 THEN Ctrl46 := Ctrl46 - 1; END_IF Ctrl47 := Ctrl47 OR Ctrl48; Ctrl48 := Ctrl48 + 1; Ctrl49 := Ctrl49 * 2; IF Ctrl50 > 0 THEN Ctrl50 := Ctrl50 - 1; END_IF Ctrl51 := Ctrl51 OR Ctrl52; Ctrl52 := Ctrl52 + 1; Ctrl53 := Ctrl53 * 2; IF Ctrl54 > 0 THEN Ctrl54 := Ctrl54 - 1; END_IF Ctrl55 := Ctrl55 OR Ctrl56; Ctrl56 := Ctrl56 + 1; Ctrl57 := Ctrl57 * 2; IF Ctrl58 > 0 THEN Ctrl58 := Ctrl58 - 1; END_IF Ctrl59 := Ctrl59 OR Ctrl60; Ctrl60 := Ctrl60 + 1; Ctrl61 := Ctrl61 * 2; IF Ctrl62 > 0 THEN Ctrl62 := Ctrl62 - 1; END_IF Ctrl63 := Ctrl63 OR Ctrl64; Ctrl64 := Ctrl64 + 1; Ctrl65 := Ctrl65 * 2; IF Ctrl66 > 0 THEN Ctrl66 := Ctrl66 - 1; END_IF Ctrl67 := Ctrl67 OR Ctrl68; Ctrl68 := Ctrl68 + 1; Ctrl69 := Ctrl69 * 2; IF Ctrl70 > 0 THEN Ctrl70 := Ctrl70 - 1; END_IF Ctrl71 := Ctrl71 OR Ctrl72; Ctrl72 := Ctrl72 + 1; Ctrl73 := Ctrl73 * 2; IF Ctrl74 > 0 THEN Ctrl74 := Ctrl74 - 1; END_IF Ctrl75 := Ctrl75 OR Ctrl76; Ctrl76 := Ctrl76 + 1; Ctrl77 := Ctrl77 * 2; IF Ctrl78 > 0 THEN Ctrl78 := Ctrl78 - 1; END_IF Ctrl79 := Ctrl79 OR Ctrl80; Ctrl80 := Ctrl80 + 1; Ctrl81 := Ctrl81 * 2; IF Ctrl82 > 0 THEN Ctrl82 := Ctrl82 - 1; END_IF Ctrl83 := Ctrl83 OR Ctrl84; Ctrl84 := Ctrl84 + 1; Ctrl85 := Ctrl85 * 2; IF Ctrl86 > 0 THEN Ctrl86 := Ctrl86 - 1; END_IF Ctrl87 := Ctrl87 OR Ctrl88; Ctrl88 := Ctrl88 + 1; Ctrl89 := Ctrl89 * 2; IF Ctrl90 > 0 THEN Ctrl90 := Ctrl90 - 1; END_IF Ctrl91 := Ctrl91 OR Ctrl92; Ctrl92 := Ctrl92 + 1; Ctrl93 := Ctrl93 * 2; IF Ctrl94 > 0 THEN Ctrl94 := Ctrl94 - 1; END_IF Ctrl95 := Ctrl95 OR Ctrl96; Ctrl96 := Ctrl96 + 1; Ctrl97 := Ctrl97 * 2; IF Ctrl98 > 0 THEN Ctrl98 := Ctrl98 - 1; END_IF Ctrl99 := Ctrl99 OR Ctrl0;]]>
