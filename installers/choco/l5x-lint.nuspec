<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>l5x-lint</id>
    <version>0.0.0</version> <!-- stamped by CI from VERSION at release -->
    <title>l5x-lint</title>
    <authors>JohnPrice</authors>
    <projectUrl>https://github.com/JohnPrice/l5x-lint</projectUrl>
    <licenseUrl>https://github.com/JohnPrice/l5x-lint/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Semantic linter for Rockwell Logix L5X PLC programs</description>
    <summary>Parses L5X XML and analyzes RLL/ST routine bodies for semantic issues</summary>
    <releaseNotes>https://github.com/JohnPrice/l5x-lint/releases</releaseNotes>
    <tags>plc rockwell logix l5x linter automation</tags>
    <icon>l5x-lint.png</icon>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="l5x-lint.png" target="l5x-lint.png" />
  </files>
</package>
