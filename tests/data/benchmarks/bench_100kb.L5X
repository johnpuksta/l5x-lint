<Routine Name="STLogic" Type="ST">
<STContent>
<![CDATA[Ctrl0 := Ctrl0 + 1; Ctrl1 := Ctrl1 * 2; IF Ctrl2 > 0 THEN Ctrl2 := Ctrl2 - 1; END_IF Ctrl3 := Ctrl3 OR Ctrl4; Ctrl4 := Ctrl4 + 1; Ctrl5 := Ctrl5 * 2; IF Ctrl6 > 0 THEN Ctrl6 := Ctrl6 - 1; END_IF Ctrl7 := Ctrl7 OR Ctrl8; Ctrl8 := Ctrl8 + 1; Ctrl9 := Ctrl9 * 2; IF Ctrl10 > 0 THEN Ctrl10 := Ctrl10 - 1; END_IF Ctrl11 := Ctrl11 OR Ctrl12; Ctrl12 := Ctrl12 + 1; Ctrl13 := Ctrl13 * 2; IF Ctrl14 > 0 THEN Ctrl14 := Ctrl14 - 1; END_IF Ctrl15 := Ctrl15 OR Ctrl16; Ctrl16 := Ctrl16 + 1; Ctrl17 := Ctrl17 * 2; IF Ctrl18 > 0 THEN Ctrl18 := Ctrl18 - 1; END_IF Ctrl19 := Ctrl19 OR Ctrl20; Ctrl20 := Ctrl20 + 1; Ctrl21 := Ctrl21 * 2; IF Ctrl22 > 0 THEN Ctrl22 := Ctrl22 - 1; END_IF Ctrl23 := Ctrl23 OR Ctrl24; Ctrl24 := Ctrl24 + 1; Ctrl25 := Ctrl25 * 2; IF Ctrl26 > 0 THEN Ctrl26 := Ctrl26 - 1; END_IF Ctrl27 := Ctrl27 OR Ctrl28; Ctrl28 := Ctrl28 + 1; Ctrl29 := Ctrl29 * 2;]]>
</STContent>
</Routine>
